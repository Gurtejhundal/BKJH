[Unit]
Description=Gunicorn daemon for Bibi Kaulan Ji Hospital website
After=network.target

[Service]
User=hospitalweb
Group=www-data
WorkingDirectory=/home/hospitalweb/hospital-site
Environment="DJANGO_SETTINGS_MODULE=config.settings.production"
EnvironmentFile=/home/hospitalweb/hospital-site/.env
ExecStart=/home/hospitalweb/hospital-site/.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
